#!/usr/bin/env sh
set -eu

# Run checks only when staged TypeScript files under src/ are included in the commit.
staged_ts_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^src/.*\.(ts|tsx)$' || true)

if [ -z "$staged_ts_files" ]; then
  echo "pre-commit: no staged TypeScript files in src/, skipping checks"
  exit 0
fi

echo "pre-commit: running typecheck, lint, and format check"
npm run check
